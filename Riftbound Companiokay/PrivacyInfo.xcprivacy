<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- No tracking, no ad/analytics SDKs, no cross-app tracking. -->
	<key>NSPrivacyTracking</key>
	<false/>
	<key>NSPrivacyTrackingDomains</key>
	<array/>
	<!--
	  Data Not Collected. Login credentials are transmitted only to the Riftbound
	  Locator to authenticate the current request and are not retained by this app;
	  tournament/store data is fetched live and shown, not stored. Only an opaque
	  login token is kept on device (Keychain) so the session can persist.
	-->
	<key>NSPrivacyCollectedDataTypes</key>
	<array/>
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<!-- CA92.1: read/write the app's own preferences. -->
				<string>CA92.1</string>
				<!-- 1C8F.1: shared scoreboard via the app's App Group (app + widget). -->
				<string>1C8F.1</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
